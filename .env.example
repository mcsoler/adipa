# PostgreSQL
POSTGRES_USER=adipa
POSTGRES_PASSWORD=adipa_secret
POSTGRES_DB=adipa_db

# Backend
DATABASE_URL=postgresql+asyncpg://adipa:adipa_secret@postgres:5432/adipa_db
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
# Un solo origen:
CORS_ORIGINS=http://localhost:8080
# Múltiples orígenes (separados por coma):
# CORS_ORIGINS=http://localhost:8080,http://tudominio.com:8080

# Frontend (debe apuntar al backend)
VITE_API_URL=http://localhost:5000
